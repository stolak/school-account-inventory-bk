// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// datasource db {
// provider = "postgresql"
// url      = env("DATABASE_URL")
// }

generator client {
  provider = "prisma-client-js"
}

// datasource db {
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
// }

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserType {
  Admin
  Merchant
  Buyer
}

enum Role {
  Visitor
  Admin
  Merchant
  Buyer
  SuperAdmin
  CustomerSupport
}

enum DocumentStatus {
  Pending
  Approved
  Rejected
}

enum Status {
  Active
  Inactive
  Archived
}

model User {
  id              String   @id @default(uuid()) @db.Char(36)
  password        String
  firstName       String?
  lastName        String?
  profileImageUrl String?
  phoneNumber     String?
  email           String   @unique
  userType        UserType @default(Buyer)
  role            Role     @default(Visitor)
  isActive        Boolean  @default(false)
  isVerified      Boolean  @default(false)
  isEmailVerified Boolean  @default(false)
  isPhoneVerified Boolean  @default(false)
  isDeleted       Boolean  @default(false)

  createdById  String? @db.Char(36)
  approvedById String? @db.Char(36)
  modifiedById String? @db.Char(36)

  createdBy  User? @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy User? @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  modifiedBy User? @relation("ModifiedBy", fields: [modifiedById], references: [id], onDelete: SetNull)

  createdUsers  User[] @relation("CreatedBy")
  approvedUsers User[] @relation("ApprovedBy")
  modifiedUsers User[] @relation("ModifiedBy")

  status       String   @default("active")
  referralCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Password reset tokens
  passwordResetTokens PasswordResetToken[]

  // Inventory/School domain relations
  userRoles                          UserRole[]
  createdInventoryItems              InventoryItem[]              @relation("InventoryItemCreatedBy")
  createdSuppliers                   Supplier[]                   @relation("SupplierCreatedBy")
  createdSupplierTransactions        SupplierTransaction[]        @relation("SupplierTransactionCreatedBy")
  createdSchoolClasses               SchoolClass[]                @relation("SchoolClassCreatedBy")
  createdStudents                    Student[]                    @relation("StudentCreatedBy")
  classTeacherAssignments            ClassTeacher[]               @relation("ClassTeacherTeacher")
  createdClassTeachers               ClassTeacher[]               @relation("ClassTeacherCreatedBy")
  createdClassInventoryDistributions ClassInventoryDistribution[] @relation("ClassInventoryDistributionCreatedBy")
  inventoryTransactionsReceived      InventoryTransaction[]       @relation("InventoryTransactionReceiver")
  createdInventoryTransactions       InventoryTransaction[]       @relation("InventoryTransactionCreatedBy")
  createdClassInventoryEntitlements  ClassInventoryEntitlement[]  @relation("ClassInventoryEntitlementCreatedBy")
  createdStudentInventoryLogs        StudentInventoryLog[]        @relation("StudentInventoryLogCreatedBy")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @db.Char(36)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Bank {
  id       String @id @default(uuid()) @db.Char(36)
  bankCode String @unique
  bankName String
}

enum RecordStatus {
  active
  inactive
  archived
}

enum StudentStatus {
  Active
  Inactive
  Graduated
  Transferred
  Suspended
  Archived
}

enum Gender {
  male
  female
  other
}

enum InventoryTransactionType {
  purchase
  donation
  student_purchase

  student_collection
  hostel_collection
  departmental_collection
  staff_collection

  student_return
  hostel_return
  departmental_return
  staff_return

  sales
  disposal
}

enum InventoryTransactionStatus {
  pending
  cancelled
  deleted
  completed
}

enum ClassTeacherRole {
  class_teacher
  assistant_teacher
  subject_teacher
}

model Category {
  id             String          @id @default(uuid()) @db.Char(36)
  name           String          @unique
  description    String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @map("updated_at")
  status         Status          @default(Active)
  subCategories  SubCategory[]
  inventoryItems InventoryItem[]

  @@map("categories")
}

/// Named `AppRole` to avoid colliding with your existing `Role` enum.
model AppRole {
  code      String   @id @db.VarChar(50)
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  roleMenus      RoleMenu[]
  userRoles      UserRole[]
  rolePrivileges RolePrivilege[]

  @@map("roles")
}

model Menu {
  id        String   @id @default(uuid()) @db.Char(36)
  route     String   @unique
  caption   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  roleMenus RoleMenu[]

  @@map("menus")
}

model RoleMenu {
  id       String @id @default(uuid()) @db.Char(36)
  roleCode String @map("role_code") @db.VarChar(50)
  menuId   String @map("menu_id") @db.Char(36)

  role AppRole @relation(fields: [roleCode], references: [code], onDelete: Cascade)
  menu Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([roleCode, menuId])
  @@index([roleCode])
  @@index([menuId])
  @@map("role_menus")
}

model UserRole {
  userId   String @id @map("user_id") @db.Char(36)
  roleCode String @map("role_code") @db.VarChar(50)

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role AppRole @relation(fields: [roleCode], references: [code], onDelete: Cascade)

  @@index([roleCode])
  @@map("user_roles")
}

model RolePrivilege {
  id          String   @id @default(uuid()) @db.Char(36)
  roleCode    String   @map("role_code") @db.VarChar(50)
  description String
  status      Status   @default(Active)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  role AppRole @relation(fields: [roleCode], references: [code], onDelete: Cascade)

  @@unique([roleCode, description])
  @@index([roleCode])
  @@map("role_privileges")
}

model SubCategory {
  id          String   @id @default(uuid()) @db.Char(36)
  name        String
  description String?
  categoryId  String?  @map("category_id") @db.Char(36)
  status      Status   @default(Active)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  category       Category?       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  inventoryItems InventoryItem[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@map("sub_categories")
}

model Brand {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @unique
  status    Status   @default(Active)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  inventoryItems InventoryItem[]

  @@map("brands")
}

model Uom {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @unique
  symbol    String   @unique
  status    Status   @default(Active)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  inventoryItems InventoryItem[]

  @@map("uoms")
}

model InventoryItem {
  id                String   @id @default(uuid()) @db.Char(36)
  sku               String?  @unique
  name              String   @unique
  categoryId        String?  @map("category_id") @db.Char(36)
  subCategoryId     String?  @map("sub_category_id") @db.Char(36)
  brandId           String?  @map("brand_id") @db.Char(36)
  uomId             String?  @map("uom_id") @db.Char(36)
  barcode           String?  @unique
  costPrice         Decimal  @map("cost_price") @db.Decimal(12, 2)
  sellingPrice      Decimal  @map("selling_price") @db.Decimal(12, 2)
  lowStockThreshold Int      @default(0) @map("low_stock_threshold")
  createdById       String?  @map("created_by") @db.Char(36)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")

  category                    Category?                    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subCategory                 SubCategory?                 @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)
  brand                       Brand?                       @relation(fields: [brandId], references: [id], onDelete: Restrict)
  uom                         Uom?                         @relation(fields: [uomId], references: [id], onDelete: Restrict)
  createdBy                   User?                        @relation("InventoryItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  status                      Status                       @default(Active)
  inventoryTransactions       InventoryTransaction[]
  classInventoryDistributions ClassInventoryDistribution[]
  classInventoryEntitlements  ClassInventoryEntitlement[]
  studentInventoryLogs        StudentInventoryLog[]

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([brandId])
  @@index([uomId])
  @@index([createdById])
  @@map("inventory_items")
}

model Supplier {
  id          String   @id @default(uuid()) @db.Char(36)
  name        String   @unique
  contactName String?  @map("contact_name")
  email       String?
  phone       String?
  address     String?
  city        String?
  state       String?
  country     String?
  website     String?
  notes       String?
  status      Status   @default(Active)
  createdById String?  @map("created_by") @db.Char(36)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  createdBy             User?                  @relation("SupplierCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  supplierTransactions  SupplierTransaction[]
  inventoryTransactions InventoryTransaction[]

  @@index([createdById])
  @@map("suppliers")
}

model SupplierTransaction {
  id              String   @id @default(uuid()) @db.Char(36)
  supplierId      String?  @map("supplier_id") @db.Char(36)
  transactionDate DateTime @map("transaction_date")
  credit          Decimal  @db.Decimal(12, 2)
  debit           Decimal  @db.Decimal(12, 2)
  referenceNo     String?  @map("reference_no")
  notes           String?
  createdById     String?  @map("created_by") @db.Char(36)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  supplier  Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("SupplierTransactionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([supplierId])
  @@index([createdById])
  @@map("supplier_transactions")
}

model SchoolClass {
  id                          String                       @id @default(uuid()) @db.Char(36)
  name                        String                       @unique
  status                      Status                       @default(Active)
  createdById                 String                       @map("created_by") @db.Char(36)
  createdAt                   DateTime                     @default(now()) @map("created_at")
  updatedAt                   DateTime                     @default(now()) @map("updated_at")
  createdBy                   User                         @relation("SchoolClassCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  students                    Student[]
  classInventoryDistributions ClassInventoryDistribution[]
  classInventoryEntitlements  ClassInventoryEntitlement[]
  studentInventoryLogs        StudentInventoryLog[]
  classTeachers               ClassTeacher[]

  @@index([createdById])
  @@map("school_classes")
}

model Student {
  id              String        @id @default(uuid()) @db.Char(36)
  admissionNumber String        @unique @map("admission_number")
  firstName       String        @map("first_name")
  middleName      String?       @map("middle_name")
  lastName        String        @map("last_name")
  studentEmail    String?       @map("student_email")
  gender          Gender
  dateOfBirth     DateTime      @map("date_of_birth") @db.Date
  classId         String?       @map("class_id") @db.Char(36)
  guardianName    String?       @map("guardian_name")
  guardianEmail   String?       @map("guardian_email")
  guardianContact String?       @map("guardian_contact")
  address         String?
  status          StudentStatus @default(Active)
  createdById     String        @map("created_by") @db.Char(36)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @default(now()) @map("updated_at")

  class     SchoolClass? @relation(fields: [classId], references: [id], onDelete: SetNull)
  createdBy User         @relation("StudentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  studentInventoryLogs StudentInventoryLog[]

  @@index([classId])
  @@index([createdById])
  @@map("students")
}

model AcademicSessionTerm {
  id        String   @id @default(uuid()) @db.Char(36)
  session   String   @db.VarChar(50)
  name      String   @db.VarChar(100)
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  status    Status   @default(Active)
  createdAt DateTime @default(now()) @map("created_at")

  classInventoryDistributions ClassInventoryDistribution[]
  classInventoryEntitlements  ClassInventoryEntitlement[]
  studentInventoryLogs        StudentInventoryLog[]

  @@unique([session, name])
  @@map("academic_session_terms")
}

model ClassTeacher {
  id           String           @id @default(uuid()) @db.Char(36)
  classId      String?          @map("class_id") @db.Char(36)
  teacherId    String           @unique @map("teacher_id") @db.Char(36)
  email        String           @unique
  name         String
  role         ClassTeacherRole @default(class_teacher)
  status       Status           @default(Active)
  assignedAt   DateTime         @default(now()) @map("assigned_at")
  unassignedAt DateTime?        @map("unassigned_at")
  createdById  String           @map("created_by") @db.Char(36)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @default(now()) @map("updated_at")

  class     SchoolClass? @relation(fields: [classId], references: [id], onDelete: SetNull)
  teacher   User         @relation("ClassTeacherTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  createdBy User         @relation("ClassTeacherCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  receivedDistributions ClassInventoryDistribution[] @relation("DistributionReceivedBy")
  givenStudentLogs      StudentInventoryLog[]        @relation("StudentLogGivenBy")

  @@index([classId])
  @@index([teacherId])
  @@index([createdById])
  @@map("class_teachers")
}

model ClassInventoryDistribution {
  id                  String   @id @default(uuid()) @db.Char(36)
  classId             String?  @map("class_id") @db.Char(36)
  inventoryItemId     String   @map("inventory_item_id") @db.Char(36)
  sessionTermId       String   @map("session_term_id") @db.Char(36)
  distributedQuantity Int      @map("distributed_quantity")
  distributionDate    DateTime @default(now()) @map("distribution_date")
  receivedById        String?  @map("received_by") @db.Char(36)
  receiverName        String?  @map("receiver_name")
  notes               String?
  createdById         String   @map("created_by") @db.Char(36)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @map("updated_at")

  class         SchoolClass?        @relation(fields: [classId], references: [id], onDelete: SetNull)
  inventoryItem InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  sessionTerm   AcademicSessionTerm @relation(fields: [sessionTermId], references: [id], onDelete: Restrict)
  receivedBy    ClassTeacher?       @relation("DistributionReceivedBy", fields: [receivedById], references: [id], onDelete: Restrict)
  createdBy     User                @relation("ClassInventoryDistributionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  inventoryTransactions InventoryTransaction[]

  @@index([classId])
  @@index([inventoryItemId])
  @@index([sessionTermId])
  @@index([receivedById])
  @@index([createdById])
  @@map("class_inventory_distributions")
}

model InventoryTransaction {
  id               String                     @id @default(uuid()) @db.Char(36)
  itemId           String                     @map("item_id") @db.Char(36)
  supplierId       String?                    @map("supplier_id") @db.Char(36)
  receiverId       String?                    @map("receiver_id") @db.Char(36)
  supplierReceiver String?                    @map("supplier_receiver")
  transactionType  InventoryTransactionType   @map("transaction_type")
  qtyIn            Decimal                    @default(0) @map("qty_in") @db.Decimal(12, 2)
  inCost           Decimal                    @default(0) @map("in_cost") @db.Decimal(12, 2)
  qtyOut           Decimal                    @default(0) @map("qty_out") @db.Decimal(12, 2)
  outCost          Decimal                    @default(0) @map("out_cost") @db.Decimal(12, 2)
  amountPaid       Decimal                    @default(0) @map("amount_paid") @db.Decimal(12, 2)
  status           InventoryTransactionStatus @default(pending)
  referenceNo      String?                    @map("reference_no")
  notes            String?
  studentId        String?                    @map("student_id") @db.Char(36)
  classId          String?                    @map("class_id") @db.Char(36)
  termId           String?                    @map("term_id") @db.Char(36)

  transactionDate DateTime @default(now()) @map("transaction_date")
  createdById     String   @map("created_by") @db.Char(36)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  item                         InventoryItem               @relation(fields: [itemId], references: [id], onDelete: Restrict)
  supplier                     Supplier?                   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  receiver                     User?                       @relation("InventoryTransactionReceiver", fields: [receiverId], references: [id], onDelete: SetNull)
  createdBy                    User                        @relation("InventoryTransactionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  classInventoryDistribution   ClassInventoryDistribution? @relation(fields: [classInventoryDistributionId], references: [id])
  classInventoryDistributionId String?                     @db.Char(36)

  @@index([itemId])
  @@index([supplierId])
  @@index([receiverId])
  @@index([createdById])
  @@map("inventory_transactions")
}

model ClassInventoryEntitlement {
  id              String   @id @default(uuid()) @db.Char(36)
  classId         String?  @map("class_id") @db.Char(36)
  inventoryItemId String   @map("inventory_item_id") @db.Char(36)
  sessionTermId   String   @map("session_term_id") @db.Char(36)
  quantity        Int
  notes           String?
  createdById     String   @map("created_by") @db.Char(36)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  class         SchoolClass?        @relation(fields: [classId], references: [id], onDelete: SetNull)
  inventoryItem InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  sessionTerm   AcademicSessionTerm @relation(fields: [sessionTermId], references: [id], onDelete: Restrict)
  createdBy     User                @relation("ClassInventoryEntitlementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([classId, inventoryItemId, sessionTermId])
  @@index([classId])
  @@index([inventoryItemId])
  @@index([sessionTermId])
  @@index([createdById])
  @@map("class_inventory_entitlements")
}

model StudentInventoryLog {
  id              String    @id @default(uuid()) @db.Char(36)
  studentId       String    @map("student_id") @db.Char(36)
  classId         String?   @map("class_id") @db.Char(36)
  sessionTermId   String    @map("session_term_id") @db.Char(36)
  inventoryItemId String    @map("inventory_item_id") @db.Char(36)
  qty             Int
  eligible        Boolean   @default(true)
  received        Boolean   @default(false)
  receivedDate    DateTime? @map("received_date")
  givenById       String?   @map("given_by") @db.Char(36)
  createdById     String    @map("created_by") @db.Char(36)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")

  student       Student             @relation(fields: [studentId], references: [id], onDelete: Restrict)
  class         SchoolClass?        @relation(fields: [classId], references: [id], onDelete: SetNull)
  sessionTerm   AcademicSessionTerm @relation(fields: [sessionTermId], references: [id], onDelete: Restrict)
  inventoryItem InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  givenBy       ClassTeacher?       @relation("StudentLogGivenBy", fields: [givenById], references: [id], onDelete: Restrict)
  createdBy     User                @relation("StudentInventoryLogCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([classId])
  @@index([sessionTermId])
  @@index([inventoryItemId])
  @@index([givenById])
  @@index([createdById])
  @@map("student_inventory_log")
}
